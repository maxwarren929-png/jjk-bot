{
  "env": {
    "node": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-undef": "error",
    "no-const-assign": "error",
    "no-dupe-keys": "error",
    "no-duplicate-case": "error",
    "no-extra-semi": "warn",
    "no-irregular-whitespace": "error",
    "no-unreachable": "error",
    "valid-typeof": "error",
    "semi": ["warn", "always"],
    "eqeqeq": ["warn", "always"],
    "curly": "warn"
  }
}
